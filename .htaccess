# MyCSU portal routing & security
Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    # No RewriteBase set — Apache uses the directory's own path as base,
    # which is correct for both:
    #   - localhost/mycsu/  (local dev, base = /mycsu/)
    #   - login.csu.edu.ph/ (production root, base = /)

    # Redirect direct HTML access to PHP entry
    RewriteCond %{THE_REQUEST} \s/+index\.html\s [NC]
    RewriteRule ^index\.html$ index.php [R=301,L]

    # Ensure Admin Portal works via /admin as well as /admin/
    RewriteRule ^admin/?$ admin/index.php [L]

    # DirectoryIndex above already serves index.php for bare directory requests.
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
